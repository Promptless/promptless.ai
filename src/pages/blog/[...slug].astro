---
import { getCollection, render } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import BlogAuthorCard from '@components/site/BlogAuthorCard.astro';

export async function getStaticPaths() {
  const entries = await getCollection('blog', ({ data }) => !data.hidden);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const siteUrl = (import.meta.env.SITE || 'https://promptless.ai').trim();
const pageUrl = `${siteUrl}/blog/${entry.slug}`;
const socialImageHead = entry.data.socialImage
  ? [
      { tag: 'meta' as const, attrs: { property: 'og:image', content: `${siteUrl}${entry.data.socialImage}` } },
      { tag: 'meta' as const, attrs: { property: 'og:image:width', content: '1200' } },
      { tag: 'meta' as const, attrs: { property: 'og:image:height', content: '627' } },
      { tag: 'meta' as const, attrs: { name: 'twitter:image', content: `${siteUrl}${entry.data.socialImage}` } },
      { tag: 'meta' as const, attrs: { name: 'twitter:card', content: 'summary_large_image' } },
    ]
  : [];

const baseHead = [
  { tag: 'meta' as const, attrs: { property: 'og:title', content: entry.data.title } },
  { tag: 'meta' as const, attrs: { property: 'og:description', content: entry.data.description } },
  { tag: 'meta' as const, attrs: { property: 'og:url', content: pageUrl } },
  { tag: 'meta' as const, attrs: { property: 'og:type', content: 'article' } },
];

const pageHead = [...baseHead, ...socialImageHead];
const hasAuthor = Boolean(entry.data.author);
---

<StarlightPage
  hasSidebar={false}
  headings={headings}
  frontmatter={{
    title: entry.data.title,
    description: entry.data.description,
    template: 'doc',
    editUrl: false,
    head: pageHead,
  }}
>
  <div class:list={['blog-layout', { 'blog-layout--has-aside': hasAuthor }]}>
    <div class="blog-prose">
      <p class="collection-back-link">
        <a href="/blog">← Back to Blog</a>
      </p>
      <Content />
      <p class="collection-back-link collection-back-link-bottom">
        <a href="/blog">← Back to Blog</a>
      </p>
    </div>

    {hasAuthor && (
      <aside class="blog-author-aside">
        <div class="blog-author-sticky">
          <BlogAuthorCard
            author={entry.data.author!}
            pageUrl={pageUrl}
          />
        </div>
      </aside>
    )}
  </div>
</StarlightPage>
