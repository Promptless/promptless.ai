---
// Public share page for skill-issue report cards. Static + client-fetch: the slug
// comes from the /skill-issue/<slug> path (a vercel.json rewrite serves this page
// for those URLs), and the card is fetched from the runtime free-tools endpoint.
// Styles must be `is:global` — the card markup is injected at runtime, so Astro's
// default scoped styles (keyed to build-time elements) would never match it.
// Per-card OG images need SSR/prerender — v1 ships a generic unfurl.
const API_BASE = 'https://api.gopromptless.ai/public/free-tools/report-cards';
const DEMO_URL = 'https://cal.com/team/promptless/promptless-for-agents-intro-call';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Skill Issue — Report Card</title>
    <meta name="description" content="A report card for an AI agent setup. Grade yours with npx skill-issue." />
    <meta property="og:title" content="Skill Issue — Report Card" />
    <meta property="og:description" content="Grade your AI agent setup — npx skill-issue. Nothing leaves your machine." />
    <meta name="twitter:card" content="summary" />
    <style is:global>
      :root {
        --primary: #506aea; --tint: #e7efff; --card-from: #0a0a14; --card-to: #1a2350;
        --bg: #0d0f16; --fg: #e8eaf1; --muted: #969cab; --line: #23283a; --panel: #141826;
        --good: #1a9c6b; --warn: #d8a13a; --bad: #e2554f;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: var(--bg); color: var(--fg); min-height: 100vh; padding: 40px 20px;
        font: 15px/1.55 -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      }
      main { max-width: 820px; margin: 0 auto; }
      .card {
        border-radius: 18px; padding: 34px 36px; color: #fff;
        background: radial-gradient(120% 160% at 85% -20%, var(--card-to) 0%, var(--card-from) 62%);
        border: 1px solid #2a3354;
      }
      .row { display: flex; align-items: flex-start; justify-content: space-between; gap: 24px; }
      .letter {
        font-size: clamp(64px, 15vw, 120px); font-weight: 800; letter-spacing: -0.02em; line-height: 0.9;
        color: var(--primary); text-shadow: 0 0 46px rgba(80, 106, 234, 0.45);
      }
      .gpa { font-size: clamp(14px, 3vw, 20px); color: #cdd6fb; margin-top: 8px; font-weight: 600; }
      .stats { text-align: right; min-width: 0; }
      .stats .wow b {
        display: block; font-size: clamp(26px, 6vw, 44px); font-weight: 800; color: #fff; line-height: 1;
        letter-spacing: -0.01em; font-variant-numeric: tabular-nums;
      }
      .stats .wow span { display: block; font-size: clamp(12px, 2.4vw, 15px); color: #aeb9e8; margin-top: 5px; }
      .stats .sub { margin-top: 14px; font-size: clamp(12px, 2.2vw, 14px); color: #c7cef2; }
      .stats .sub b { color: #fff; } .stats .sub div { margin: 4px 0; }
      .foot {
        display: flex; justify-content: space-between; align-items: baseline; margin-top: 44px;
        font-size: clamp(11px, 2vw, 14px); color: #8e97c0;
      }
      .foot a { color: inherit; text-decoration: underline; text-underline-offset: 2px; }
      .foot code { color: var(--tint); background: rgba(80, 106, 234, 0.18); padding: 3px 9px; border-radius: 6px; }
      h2 { margin: 36px 0 14px; font-size: 19px; }
      .dims { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 10px; }
      @media (max-width: 680px) { .dims { grid-template-columns: repeat(2, 1fr); } }
      .dcard { border: 1px solid var(--line); border-radius: 12px; padding: 14px 15px; background: var(--panel); }
      .dcard .cat { font-weight: 700; font-size: 14px; }
      .dcard .sc {
        display: block; margin-top: 8px; font-size: 30px; font-weight: 800; line-height: 1;
        font-variant-numeric: tabular-nums; letter-spacing: -0.01em;
      }
      .dcard .sc small { font-size: 13px; font-weight: 600; color: var(--muted); margin-left: 1px; }
      .sc.good { color: var(--good); } .sc.warn { color: var(--warn); } .sc.bad { color: var(--bad); }
      .sc.na { color: var(--muted); font-size: 15px; font-weight: 700; }
      .meter { height: 5px; border-radius: 3px; background: var(--line); margin-top: 11px; overflow: hidden; }
      .meter i { display: block; height: 100%; border-radius: 3px; }
      .meter i.good { background: var(--good); } .meter i.warn { background: var(--warn); } .meter i.bad { background: var(--bad); }
      .cta {
        margin-top: 28px; border: 1px solid var(--line); border-left: 4px solid var(--primary);
        border-radius: 10px; padding: 16px 18px; background: var(--panel);
      }
      .cta a { color: var(--primary); font-weight: 600; text-decoration: none; }
      .cta code { color: var(--tint); background: rgba(80, 106, 234, 0.14); padding: 3px 9px; border-radius: 6px; }
      .cta .line2 { margin-top: 8px; color: var(--muted); font-size: 14px; }
      .msg { text-align: center; color: var(--muted); padding: 80px 0; }
    </style>
  </head>
  <body>
    <main id="app"><div class="msg">Loading report card…</div></main>
    <script is:inline define:vars={{ API_BASE, DEMO_URL }}>
      const esc = (s) => String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
      const cap = (s) => s.charAt(0).toUpperCase() + s.slice(1);
      // Mirrors the CLI report: > 90 green, 80–90 orange, < 80 red.
      const tone = (n) => (n > 90 ? 'good' : n >= 80 ? 'warn' : 'bad');
      const GPA_POINTS = { 'A+': 4.0, A: 4.0, 'A-': 3.7, 'B+': 3.3, B: 3.0, 'B-': 2.7, 'C+': 2.3, C: 2.0, 'C-': 1.7, 'D+': 1.3, D: 1.0, 'D-': 0.7, F: 0.0, INC: null };

      const app = document.getElementById('app');
      const msg = (t) => { app.innerHTML = '<div class="msg">' + esc(t) + '</div>'; };

      const slug = location.pathname.replace(/^\/skill-issue\/?/, '').replace(/\/.*$/, '').trim();
      if (!slug) {
        msg('No report card here. Grade yours: npx skill-issue');
      } else {
        fetch(API_BASE + '/' + encodeURIComponent(slug))
          .then((r) => (r.ok ? r.json() : Promise.reject(r.status === 404 ? 'This report card doesn’t exist.' : 'Could not load this report card.')))
          .then(render)
          .catch((e) => msg(typeof e === 'string' ? e : 'Could not load this report card.'));
      }

      function wowStat(c) {
        const skills = c.skills || 0;
        const used = c.skillsUsed || 0;
        const never = skills - used;
        if (!skills) return { big: '0', label: 'skills found — running on vibes' };
        if (never / skills >= 0.3) return { big: never + ' of ' + skills, label: 'skills never fired' };
        return { big: used + ' of ' + skills, label: 'skills pulling their weight' };
      }

      function render(data) {
        const p = data.payload || {};
        const c = p.counts || {};
        const dims = Array.isArray(p.dimensions) ? p.dimensions : [];
        const grade = esc(data.grade || p.grade || '?');
        const points = Object.prototype.hasOwnProperty.call(GPA_POINTS, grade) ? GPA_POINTS[grade] : null;
        const gpaLine = points == null ? 'no GPA yet' : points.toFixed(1) + ' GPA';
        const wow = wowStat(c);

        const sub = [];
        if (c.sessions != null) sub.push('<div><b>' + c.sessions.toLocaleString() + '</b> sessions analyzed</div>');
        if (c.daysAnalyzed != null) sub.push('<div><b>' + c.daysAnalyzed + ' days</b> analyzed</div>');

        const dimCards = dims
          .map((d) => {
            const label = esc(cap(String(d.id || '')));
            if (typeof d.score !== 'number') {
              return '<div class="dcard"><span class="cat">' + label + '</span><span class="sc na">n/a</span></div>';
            }
            const t = tone(d.score);
            const w = Math.max(3, d.score);
            return (
              '<div class="dcard"><span class="cat">' + label + '</span>' +
              '<span class="sc ' + t + '">' + d.score + '<small>/100</small></span>' +
              '<div class="meter"><i class="' + t + '" style="width:' + w + '%"></i></div></div>'
            );
          })
          .join('');

        app.innerHTML =
          '<div class="card">' +
          '<div class="row">' +
          '<div><div class="letter">' + grade + '</div><div class="gpa">' + esc(gpaLine) + '</div></div>' +
          '<div class="stats"><div class="wow"><b>' + esc(wow.big) + '</b><span>' + esc(wow.label) + '</span></div>' +
          (sub.length ? '<div class="sub">' + sub.join('') + '</div>' : '') +
          '</div></div>' +
          '<div class="foot"><span>Skill Issue · by <a href="https://promptless.ai">Promptless</a></span><code>npx skill-issue</code></div>' +
          '</div>' +
          (dimCards ? '<h2>Dimensions</h2><div class="dims">' + dimCards + '</div>' : '') +
          '<div class="cta">Promptless keeps your agent instructions self-healing and improving as your codebase changes. ' +
          '<a href="' + esc(DEMO_URL) + '">Book a meeting →</a>' +
          '<div class="line2">Grade your own agent setup: <code>npx skill-issue</code> · <a href="https://promptless.ai">Promptless</a></div></div>';
      }
    </script>
  </body>
</html>
