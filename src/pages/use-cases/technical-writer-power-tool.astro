---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import Hero from '@components/site/HeroV1.astro';
import Testimonials from '@components/site/Testimonials.astro';
import ArcadeDemo from '@components/site/ArcadeDemo.astro';
import HowItWorks from '@components/site/HowItWorks.astro';
import WhyPromptless from '@components/site/WhyPromptless.astro';

const title = 'The technical writer power tool';
const description =
  'Promptless gives technical writers superpowers — draft faster, catch drift automatically, and keep every page current without the grind.';
---

<StarlightPage
  hasSidebar={false}
  frontmatter={{
    title,
    description,
    template: 'doc',
    tableOfContents: false,
    editUrl: false,
  }}
>
  <div class="pl-site-page">
    <Hero
      prefix="Your docs, always"
      words={['accurate', 'current', 'consistent', 'published', 'reviewed', 'up to date', 'accurate']}
      subtitle="Promptless is the technical writer's power tool — it drafts updates from code changes, catches docs drift, and keeps every page current so you can focus on what matters."
    />

    <section class="pl-uc-split">
      <div class="pl-uc-split-text">
        <h2>See it in action</h2>
        <p>Watch how Promptless turns a code change into a docs update in minutes — no context-switching, no stale pages.</p>
      </div>
      <div class="pl-uc-split-video">
        <div class="pl-site-video-embed">
          <iframe
            src="https://www.youtube.com/embed/AONpRsZJkTY"
            title="Promptless for technical writers"
            allowfullscreen
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          />
        </div>
      </div>
    </section>

    <Testimonials />
    <ArcadeDemo />
    <HowItWorks />
    <WhyPromptless />
  </div>
</StarlightPage>
