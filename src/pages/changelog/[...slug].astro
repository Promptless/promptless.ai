---
import { getCollection, render } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

export async function getStaticPaths() {
  const entries = (await getCollection('changelog', ({ data }) => !data.hidden)).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
  );
  return entries.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      newer: entries[i - 1] ?? null,
      older: entries[i + 1] ?? null,
    },
  }));
}

const { entry, newer, older } = Astro.props;
const { Content, headings } = await render(entry);
---

<StarlightPage
  hasSidebar={false}
  headings={headings}
  frontmatter={{
    title: entry.data.title,
    description: entry.data.description,
    template: 'doc',
    editUrl: false,
  }}
>
  <p class="collection-back-link">
    <a href="/changelog">← Back to Changelog</a>
  </p>
  <Content />
  <div class="pl-changelog-chain">
    <div>
      {older && (
        <>
          <span class="pl-changelog-chain-label">← Older</span>
          <a href={`/changelog/${older.id}`}>{older.data.title}</a>
        </>
      )}
    </div>
    <div style="text-align: right;">
      {newer && (
        <>
          <span class="pl-changelog-chain-label">Newer →</span>
          <a href={`/changelog/${newer.id}`}>{newer.data.title}</a>
        </>
      )}
    </div>
  </div>
</StarlightPage>
