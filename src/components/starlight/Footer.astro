---
import { getActiveSection } from '@lib/site-navigation';

const activeSection = getActiveSection(Astro.url.pathname);
const showFooter = activeSection !== 'none';
const currentYear = new Date().getFullYear();
---

{
  showFooter && (
    <footer class="pl-site-footer" role="contentinfo">
      <div class="pl-site-footer-nav">
        <div class="pl-site-footer-nav-group">
          <h3>Product</h3>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/pricing">Pricing</a></li>
            <li><a href="/docs">Docs</a></li>
            <li><a href="/demo">Book a demo</a></li>
          </ul>
        </div>
        <div class="pl-site-footer-nav-group">
          <h3>Content</h3>
          <ul>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/changelog">Changelog</a></li>
            <li><a href="/free-tools">Free tools</a></li>
          </ul>
        </div>
        <div class="pl-site-footer-nav-group">
          <h3>Company</h3>
          <ul>
            <li><a href="/jobs">Jobs</a></li>
            <li><a href="mailto:help@gopromptless.ai">Contact</a></li>
            <li><a href="/privacy">Privacy Policy</a></li>
            <li><a href="/terms">Terms of Use</a></li>
          </ul>
        </div>
      </div>
      <div class="pl-site-footer-inner">
        <p>Copyright &copy; {currentYear} Promptless</p>
        <p>
          <a href="mailto:help@gopromptless.ai">help@gopromptless.ai</a>
        </p>
      </div>
    </footer>
  )
}
