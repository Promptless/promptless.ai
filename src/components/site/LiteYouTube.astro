---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  id: string;
  title?: string;
  poster?: ImageMetadata | 'maxresdefault' | 'sddefault' | 'hqdefault' | 'mqdefault';
  params?: string;
  widths?: number[];
  quality?: number;
  sizes?: string;
}

const {
  id,
  title = 'YouTube video',
  poster = 'maxresdefault',
  params = 'rel=0',
  widths = [800, 1280, 1600, 1920],
  quality = 92,
  sizes = '(max-width: 700px) 100vw, min(1000px, 90vw)',
} = Astro.props;

const playParams = params ? `${params}&autoplay=1` : 'autoplay=1';
const remotePosterUrl =
  typeof poster === 'string' ? `https://i.ytimg.com/vi/${id}/${poster}.jpg` : null;
---

<link rel="preconnect" href="https://www.youtube-nocookie.com" />
{remotePosterUrl && <link rel="preconnect" href="https://i.ytimg.com" />}

<div
  class="lite-youtube"
  data-video-id={id}
  data-params={playParams}
  data-title={title}
>
  {typeof poster === 'string' ? (
    <img
      class="lite-youtube-poster"
      src={remotePosterUrl!}
      alt=""
      loading="lazy"
      decoding="async"
    />
  ) : (
    <Image
      class="lite-youtube-poster"
      src={poster}
      alt=""
      widths={widths}
      sizes={sizes}
      quality={quality}
      format="webp"
      loading="lazy"
      decoding="async"
    />
  )}
  <button type="button" class="lite-youtube-play" aria-label={`Play: ${title}`}>
    <svg viewBox="0 0 68 48" aria-hidden="true" focusable="false">
      <path
        d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z"
        fill="#f00"
      />
      <path d="M45 24 27 14v20" fill="#fff" />
    </svg>
  </button>
</div>

<style>
  .lite-youtube {
    position: absolute;
    inset: 0;
    cursor: pointer;
    background: #000;
  }
  .lite-youtube-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .lite-youtube-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 68px;
    height: 48px;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    opacity: 0.85;
    transition: opacity 0.15s ease;
  }
  .lite-youtube:hover .lite-youtube-play,
  .lite-youtube:focus-within .lite-youtube-play {
    opacity: 1;
  }
  .lite-youtube-play svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .lite-youtube iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>

<script>
  function initLiteYouTube() {
    const nodes = document.querySelectorAll<HTMLElement>(
      '.lite-youtube:not([data-activated])'
    );
    nodes.forEach((el) => {
      const activate = () => {
        if (el.dataset.activated) return;
        el.dataset.activated = 'true';
        const id = el.dataset.videoId;
        const params = el.dataset.params || 'autoplay=1';
        const title = el.dataset.title || 'YouTube video';
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube-nocookie.com/embed/${id}?${params}`;
        iframe.title = title;
        iframe.setAttribute(
          'allow',
          'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share; fullscreen'
        );
        iframe.setAttribute('allowfullscreen', '');
        el.replaceChildren(iframe);
      };
      el.addEventListener('click', activate);
      el.addEventListener(
        'pointerover',
        () => {
          if (document.querySelector('link[data-lyt-warm]')) return;
          const link = document.createElement('link');
          link.rel = 'preconnect';
          link.href = 'https://www.youtube-nocookie.com';
          link.setAttribute('data-lyt-warm', 'true');
          document.head.appendChild(link);
        },
        { once: true }
      );
    });
  }
  initLiteYouTube();
  document.addEventListener('astro:page-load', initLiteYouTube);
</script>
