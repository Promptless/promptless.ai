---
import { Image } from 'astro:assets';
import mannyImg from '../../assets/site/manny.jpeg';
import alanImg from '../../assets/site/alan.jpeg';
import moImg from '../../assets/site/mo.jpeg';
import aaronImg from '../../assets/site/aaron.jpeg';
import eduardoImg from '../../assets/site/eduardo.jpeg';
import nicholasImg from '../../assets/site/nicholas.jpeg';
import docDetectiveLogo from '../../assets/site/logos/doc-detective.png';
import type { ImageMetadata } from 'astro';

interface Testimonial {
  quote: string;
  author: string;
  title: string;
  company: string;
  companyLogo: ImageMetadata | string;
  image: ImageMetadata;
}

const testimonials: Testimonial[] = [
  {
    quote:
      'Promptless is a core part of my self-healing docs toolchain, proactively fixing problems before I knew I had them.',
    author: 'Manny Silva',
    title: 'Creator',
    company: 'Doc Detective',
    companyLogo: docDetectiveLogo,
    image: mannyImg,
  },
  {
    quote:
      'Promptless dramatically speeds up my time-to-first-draft. My team literally calls me a 10x tech writer.',
    author: 'Mo King',
    title: 'Senior Technical Writer',
    company: 'Runpod',
    companyLogo: '/site/logos/runpod.png',
    image: moImg,
  },
  {
    quote:
      'This is the most "make something people want" feature I have ever seen. It solves my problem in a better way than I thought would be possible.',
    author: 'Alan Mond',
    title: 'Docs Maintainer',
    company: 'Bazel',
    companyLogo: '/site/logos/bazel-icon.png',
    image: alanImg,
  },
  {
    quote:
      "Promptless updates every relevant section of our docs, catching both the latest changes and old spots we'd missed. It feels like magic.",
    author: 'Aaron Levin',
    title: 'Founding Solutions Engineer',
    company: 'Vellum',
    companyLogo: '/site/logos/vellum-icon.svg',
    image: aaronImg,
  },
  {
    quote: 'I love your product. It works incredibly well and basically pays for itself right away.',
    author: 'Eduardo Soubihe',
    title: 'CTO',
    company: 'Latitude.sh',
    companyLogo: '/site/logos/latitude.svg',
    image: eduardoImg,
  },
  {
    quote: "Promptless is a solo tech writer's godsend.",
    author: 'Nicholas DeWald',
    title: 'Head of Developer Docs',
    company: 'Prove',
    companyLogo: '/site/logos/prove-icon.svg',
    image: nicholasImg,
  },
];
---

<section id="overview" class="pl-hero-v2">
  <div class="pl-hero-v2-left">
    <h1 class="pl-hero-v2-title">
      Write the docs.<br />Skip the busywork.
    </h1>

    <p class="pl-hero-v2-subtitle">
      Promptless suggests doc updates when your product changes. You review, edit, ship.
    </p>

    <form
      id="book-a-demo"
      class="pl-hero-v2-form"
      action="https://submit-form.com/roBOd2Oxb"
      method="post"
      data-redirect="/demo#book"
    >
      <label class="sr-only" for="work-email">Work email</label>
      <input id="work-email" type="email" name="email" placeholder="Work email" required />
      <input type="hidden" name="_redirect" value="/demo#book" />
      <button type="submit" name="submit" data-track-action="book_demo" data-track-funnel="conversion" data-track-location="hero">Get a demo</button>
    </form>
  </div>

  <div class="pl-hero-v2-right">
    <div class="pl-hero-v2-testimonials">
      {
        [...testimonials, ...testimonials].map((item) => (
          <blockquote class="pl-hero-v2-card">
            <p class="pl-hero-v2-card-quote">{item.quote}</p>
            <div class="pl-hero-v2-card-footer">
              <div class="pl-hero-v2-card-person">
                <Image src={item.image} alt={item.author} loading="lazy" width={80} height={80} />
                <div class="pl-hero-v2-card-meta">
                  <p class="pl-hero-v2-card-author">{item.author}</p>
                  <p class="pl-hero-v2-card-title">{item.title}</p>
                  <p class="pl-hero-v2-card-company">{item.company}</p>
                </div>
              </div>
              <div class="pl-hero-v2-card-logo">
                {typeof item.companyLogo === 'string' ? (
                  <img src={item.companyLogo} alt={`${item.company} logo`} loading="lazy" />
                ) : (
                  <Image src={item.companyLogo} alt={`${item.company} logo`} loading="lazy" width={40} height={40} />
                )}
              </div>
            </div>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>

<script>
  (() => {
    const form = document.getElementById('book-a-demo');
    if (!(form instanceof HTMLFormElement)) return;

    const submitButton = form.querySelector('button[type="submit"]');
    const redirectInput = form.querySelector('input[name="_redirect"]');

    if (redirectInput instanceof HTMLInputElement) {
      redirectInput.value = `${window.location.origin}/demo#book`;
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const gtag = (window as any).gtag;
      if (typeof gtag === 'function') {
        gtag('event', 'cta_click', {
          funnel_stage: 'conversion',
          action: 'book_demo',
          location: 'hero',
          campaign: '',
          link_url: form.action,
        });
      }

      const email = (form.querySelector('input[name="email"]') as HTMLInputElement)?.value?.trim();
      if (email) {
        try { sessionStorage.setItem('pl_demo_email', email); } catch {}
      }
      (window as any).posthog?.capture('email_captured', {
        intent: 'demo',
        location: 'hero',
        campaign: '',
        ...(email ? { $set: { email } } : {}),
      });

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = 'Submitting...';
      }

      try {
        const formData = new FormData(form);
        const payload = new URLSearchParams();
        for (const [key, value] of formData.entries()) {
          if (typeof value === 'string') payload.append(key, value);
        }

        const response = await fetch(form.action, {
          method: 'POST',
          body: payload.toString(),
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            Accept: 'application/json',
          },
        });

        if (!response.ok) {
          throw new Error(`Formspark submission failed with status ${response.status}`);
        }

        const redirectTo = form.dataset.redirect || '/demo';
        window.location.assign(redirectTo);
      } catch (_error) {
        HTMLFormElement.prototype.submit.call(form);
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
          submitButton.textContent = 'Get a demo';
        }
      }
    });
  })();
</script>

<style>
  .pl-hero-v2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    padding: 3rem 0 2rem;
  }

  .pl-hero-v2-title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0;
    color: #111827;
  }

  .pl-hero-v2-subtitle {
    margin: 1.25rem 0 0;
    font-size: 1.1rem;
    line-height: 1.55;
    color: #4b5563;
    max-width: 28rem;
  }

  .pl-hero-v2-form {
    margin-top: 2rem;
    display: flex;
    gap: 0.75rem;
  }

  .pl-hero-v2-form input[type='email'] {
    flex: 1;
    min-width: 0;
    padding: 0.75rem 1rem;
    border: 2px solid #1f2937;
    border-radius: 0.5rem;
    font-size: 1rem;
    outline: none;
  }

  .pl-hero-v2-form input[type='email']:focus {
    border-color: #506aea;
    box-shadow: 0 0 0 2px color-mix(in srgb, #506aea 30%, transparent);
  }

  .pl-hero-v2-form button {
    padding: 0.75rem 1.5rem;
    background: #506aea;
    color: #fff;
    border: none;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
  }

  .pl-hero-v2-form button:hover {
    background: #3f56d4;
  }

  /* Right column: vertical scrolling testimonials */
  .pl-hero-v2-right {
    height: 24rem;
    overflow: hidden;
    position: relative;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
  }

  .pl-hero-v2-testimonials {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    animation: hero-scroll-up 21s ease-in-out infinite;
  }

  /* 6 cards, each dwells ~3s then scrolls ~0.5s. Total 21s.
     Each card = 1/6 of 50% = 8.333% translateY.
     Each step = 1/6 of 100% duration = 16.667% of keyframes.
     Dwell takes ~85% of each step, scroll takes ~15%. */
  @keyframes hero-scroll-up {
    0%      { transform: translateY(0); }
    14.28%  { transform: translateY(0); }
    16.66%  { transform: translateY(-8.333%); }

    16.67%  { transform: translateY(-8.333%); }
    30.95%  { transform: translateY(-8.333%); }
    33.33%  { transform: translateY(-16.666%); }

    33.34%  { transform: translateY(-16.666%); }
    47.62%  { transform: translateY(-16.666%); }
    50.00%  { transform: translateY(-25%); }

    50.01%  { transform: translateY(-25%); }
    64.28%  { transform: translateY(-25%); }
    66.66%  { transform: translateY(-33.333%); }

    66.67%  { transform: translateY(-33.333%); }
    80.95%  { transform: translateY(-33.333%); }
    83.33%  { transform: translateY(-41.666%); }

    83.34%  { transform: translateY(-41.666%); }
    97.62%  { transform: translateY(-41.666%); }
    100%    { transform: translateY(-50%); }
  }

  .pl-hero-v2-testimonials:hover {
    animation-play-state: paused;
  }

  .pl-hero-v2-card {
    margin: 0;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    background: #ffffff;
    padding: 1.05rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    flex-shrink: 0;
  }

  .pl-hero-v2-card-quote {
    margin: 0;
    color: #374151;
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .pl-hero-v2-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
  }

  .pl-hero-v2-card-person {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
  }

  .pl-hero-v2-card-person img {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .pl-hero-v2-card-author {
    margin: 0;
    color: #111827;
    font-weight: 600;
    font-size: 0.875rem;
    line-height: 1.3;
  }

  .pl-hero-v2-card-title,
  .pl-hero-v2-card-company {
    margin: 0;
    color: #6b7280;
    font-size: 0.8rem;
    line-height: 1.3;
  }

  .pl-hero-v2-card-logo {
    border: 1px solid #e5e7eb;
    border-radius: 0.45rem;
    padding: 0.35rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pl-hero-v2-card-logo img {
    height: 1.25rem;
    max-height: 1.25rem;
    max-width: 6rem;
    width: auto;
    display: block;
    object-fit: contain;
  }

  @media (max-width: 768px) {
    .pl-hero-v2 {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2rem 0 1rem;
    }

    .pl-hero-v2-right {
      height: 16rem;
    }
  }
</style>
