    color: #4b5563 !important;
    text-decoration: none;
    transition: color 0.15s ease, text-decoration-color 0.15s ease, text-decoration-style 0.15s ease;
  }

  .pl-hero-v2-features a.pl-hero-v2-feature-text {
    text-decoration: underline dashed #d1d5db;
    text-underline-offset: 4px;
  }

  .pl-hero-v2-features a.pl-hero-v2-feature-text:hover,
  .pl-hero-v2-features a.pl-hero-v2-feature-text:focus-visible {
    color: #111827 !important;
    text-decoration: underline solid currentColor;
    text-underline-offset: 4px;
  }

  .pl-hero-v2-form {
    margin-top: 2rem;
    display: flex;
    gap: 0.75rem;
  }

  .pl-hero-v2-form input[type='email'] {
    flex: 1;
    min-width: 0;
    padding: 0.75rem 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
