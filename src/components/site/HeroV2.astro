  { name: 'GitLab', slug: 'gitlab', href: '/docs/integrations/' },
  { name: 'Slack', slug: 'slack', href: '/docs/integrations/slack-integration/' },
  { name: 'Jira', slug: 'jira', href: '/docs/configuring-promptless/context-sources/jira/' },
  { name: 'Linear', slug: 'linear', href: '/docs/integrations/linear-integration/' },
  { name: 'Notion', slug: 'notion', href: '/docs/integrations/' },
  { name: 'Confluence', slug: 'confluence', href: '/docs/configuring-promptless/context-sources/confluence/' },
  { name: 'GitBook', slug: 'gitbook', href: '/docs/frequently-asked-questions/recommended-docs-providers/' },
