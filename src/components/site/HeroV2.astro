    </div>

    <div
      id="pl-hero-panel-agents"
      class="pl-hero-v2-panel"
      role="tabpanel"
      aria-labelledby="pl-product-switcher-tab-agents"
      hidden
    >
      <h1 class="pl-hero-v2-title">
        Govern your agent instructions.<br />
        Skip the drift.
      </h1>

      <p class="pl-hero-v2-subtitle">
        Promptless suggests fixes when your agent instructions go stale or conflict. You review, edit, and merge.
      </p>

      <ul class="pl-hero-v2-features not-content">
        <li class="pl-hero-v2-feature">
          <svg
            class="pl-hero-v2-feature-icon"
            style="color: #0ea5e9"
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2" fill="currentColor" fill-opacity="0.08" />
            <path d="M8 7h8" />
            <path d="M8 12h8" />
            <path d="M8 17h5" />
          </svg>
          <span class="pl-hero-v2-feature-text">
            Inventories your AGENTS.md, CLAUDE.md, and Skills
          </span>
        </li>
        <li class="pl-hero-v2-feature">
          <svg
            class="pl-hero-v2-feature-icon"
            style="color: #06b6d4"
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"
              fill="currentColor"
              fill-opacity="0.12"
            />
            <path d="M12 9v4" />
            <path d="M12 17h.01" />
          </svg>
          <span class="pl-hero-v2-feature-text">
            Finds stale or conflicting instructions
          </span>
        </li>
        <li class="pl-hero-v2-feature">
          <svg
            class="pl-hero-v2-feature-icon"
            style="color: #14b8a6"
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
              fill="currentColor"
              fill-opacity="0.12"
            />
            <path d="m9 12 2 2 4-4" />
          </svg>
          <span class="pl-hero-v2-feature-text">
            Flags every change for review
          </span>
        </li>
      </ul>
    </div>
  </div>

  <form
    id="book-a-demo"
    class="pl-hero-v2-form"
    action="https://submit-form.com/roBOd2Oxb"
    method="post"
    data-redirect="/meet#book"
  >
    <label class="sr-only" for="work-email">Work email</label>
    <input id="work-email" type="email" name="email" placeholder="Work email" required />
    <input type="hidden" name="_redirect" value="/meet#book" />
    <button type="submit" name="submit" data-track-action="book_demo" data-track-funnel="conversion" data-track-location="hero">Get a demo</button>
  </form>
</section>

<script>
  (() => {
    const form = document.getElementById('book-a-demo');
    if (!(form instanceof HTMLFormElement)) return;

    const submitButton = form.querySelector('button[type="submit"]');
    const redirectInput = form.querySelector('input[name="_redirect"]');

    if (redirectInput instanceof HTMLInputElement) {
      redirectInput.value = `${window.location.origin}/meet#book`;
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const gtag = (window as any).gtag;
      if (typeof gtag === 'function') {
        gtag('event', 'cta_click', {
          funnel_stage: 'conversion',
          action: 'book_demo',
          location: 'hero',
          campaign: '',
          link_url: form.action,
        });
      }

      const email = (form.querySelector('input[name="email"]') as HTMLInputElement)?.value?.trim();
      if (email) {
        try { sessionStorage.setItem('pl_demo_email', email); } catch {}
      }
      (window as any).posthog?.capture('email_captured', {
        intent: 'demo',
        location: 'hero',
        campaign: '',
        ...(email ? { $set: { email } } : {}),
      });

      // Stash PostHog identifiers so /meet can forward them to Cal.com
      // as booking metadata, letting the webhook stitch demo_booked onto
      // the same session/person timeline.
      try {
        const ph = (window as any).posthog;
        const distinctId = ph?.get_distinct_id?.();
        const sessionId = ph?.get_session_id?.();
        if (distinctId) sessionStorage.setItem('pl_ph_distinct_id', distinctId);
        if (sessionId) sessionStorage.setItem('pl_ph_session_id', sessionId);
      } catch {}

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = 'Submitting...';
      }

      try {
        const formData = new FormData(form);
        const payload = new URLSearchParams();
        for (const [key, value] of formData.entries()) {
          if (typeof value === 'string') payload.append(key, value);
        }

        const response = await fetch(form.action, {
          method: 'POST',
          body: payload.toString(),
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            Accept: 'application/json',
          },
        });

        if (!response.ok) {
          throw new Error(`Formspark submission failed with status ${response.status}`);
        }

        const redirectTo = form.dataset.redirect || '/meet';
        window.location.assign(redirectTo);
      } catch (_error) {
        HTMLFormElement.prototype.submit.call(form);
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
          submitButton.textContent = 'Get a demo';
        }
      }
    });
  })();
</script>

<style>
  .pl-hero-v2 {
    padding: 3rem 0 2rem;
  }

  /* Both hero panels occupy the same left-column slot so switching between
     the docs and agents views causes no layout shift. Stacking them in a single
     grid cell lets the wrapper reserve the height of the tallest panel. The
     inactive panel keeps the `hidden` attribute (removing it from the a11y tree
     and tab order) but stays in layout via visibility:hidden so nothing reflows
     when the active panel changes. */
  .pl-hero-v2-panels {
    display: grid;
  }

  .pl-hero-v2-panel {
    grid-area: 1 / 1;
  }

  .pl-hero-v2-panel[hidden] {
    display: block;
    visibility: hidden;
  }

  .pl-hero-v2-title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0;
    color: #111827;
  }

  .pl-hero-v2-subtitle {
    margin: 1.25rem 0 0;
    font-size: 1.2rem;
    line-height: 1.55;
    color: #4b5563;
    max-width: 28rem;
  }

  .pl-hero-v2-features {
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: calc(0.4rem + 2px);
    color: #4b5563;
  }

  .pl-hero-v2-feature {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .pl-hero-v2-feature-stacked {
    align-items: flex-start;
  }

  .pl-hero-v2-feature-stacked .pl-hero-v2-feature-icon {
    margin-top: 0.15rem;
  }

  .pl-hero-v2-feature-content {
    display: flex;
    flex-direction: column;
    gap: calc(0.85rem + 2px);
  }

  .pl-hero-v2-toolchain {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem;
  }

  .pl-hero-v2-toolchain::before {
    content: '└─';
    color: #9ca3af;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 1rem;
    line-height: 1;
    margin-right: 0.1rem;
  }

  .pl-hero-v2-toolchain li {
    display: inline-flex;
  }

  .pl-hero-v2-toolchain a {
    display: inline-flex;
    transition: transform 0.15s ease;
  }

  .pl-hero-v2-toolchain a:hover,
  .pl-hero-v2-toolchain a:focus-visible {
    transform: translateY(2px) scale(1.1);
  }

  .pl-hero-v2-toolchain img {
    width: 20px;
    height: 20px;
    border-radius: 0;
    opacity: 0.85;
    transition: opacity 0.15s ease;
  }

  .pl-hero-v2-toolchain a:hover img,
  .pl-hero-v2-toolchain a:focus-visible img {
    opacity: 1;
  }

  .pl-hero-v2-feature-icon {
    flex-shrink: 0;
  }

  .pl-hero-v2-features .pl-hero-v2-feature-text {
    color: #4b5563 !important;
    text-decoration: none;
    transition: color 0.15s ease, text-decoration-color 0.15s ease, text-decoration-style 0.15s ease;
  }

  .pl-hero-v2-features a.pl-hero-v2-feature-text {
    text-decoration: underline dashed #d1d5db;
    text-underline-offset: 4px;
  }

  .pl-hero-v2-features a.pl-hero-v2-feature-text:hover,
  .pl-hero-v2-features a.pl-hero-v2-feature-text:focus-visible {
    color: #111827 !important;
    text-decoration: underline solid currentColor;
    text-underline-offset: 4px;
  }

  .pl-hero-v2-form {
    margin-top: 2rem;
    display: flex;
    gap: 0.75rem;
  }

  .pl-hero-v2-form input[type='email'] {
    flex: 1;
    min-width: 0;
    padding: 0.75rem 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    font-size: 1rem;
    outline: none;
  }

  .pl-hero-v2-form input[type='email']:focus {
    border-color: #506aea;
    box-shadow: 0 0 0 2px color-mix(in srgb, #506aea 30%, transparent);
  }

  .pl-hero-v2-form button {
    padding: 0.75rem 1.5rem;
    background: #0f172a;
    color: #fff;
    border: none;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
  }

  .pl-hero-v2-form button:hover {
    background: #506aea;
  }

  @media (max-width: 768px) {
    .pl-hero-v2 {
      padding: 2rem 0 1rem;
    }
  }
</style>
