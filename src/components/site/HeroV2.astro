            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2" fill="currentColor" fill-opacity="0.08" />
            <circle cx="9" cy="9" r="2" fill="currentColor" fill-opacity="0.35" />
            <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
          </svg>
          <a
            class="pl-hero-v2-feature-text"
            href="https://promptless.ai/docs/get-the-most-out/screenshots/"
            data-track-action="hero_feature"
            data-track-funnel="education"
            data-track-location="hero"
            data-track-campaign="screenshots"
          >
            Auto-updates screenshots
          </a>
        </li>
        <li class="pl-hero-v2-feature pl-hero-v2-feature-stacked">
          <svg
            class="pl-hero-v2-feature-icon"
            style="color: #14b8a6"
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M10 22V7a1 1 0 0 0-1-1H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5a1 1 0 0 0-1-1H2"
              fill="currentColor"
              fill-opacity="0.18"
            />
            <rect x="14" y="2" width="8" height="8" rx="1" fill="currentColor" fill-opacity="0.18" />
          </svg>
          <div class="pl-hero-v2-feature-content">
            <a
              class="pl-hero-v2-feature-text"
              href="https://promptless.ai/docs/integrations/"
              data-track-action="hero_feature"
              data-track-funnel="education"
              data-track-location="hero"
              data-track-campaign="toolchain"
