                    title={logo.name}
                    data-track-action="hero_toolchain"
                    data-track-funnel="education"
                    data-track-location="hero"
                    data-track-campaign={logo.slug}
                  >
                    <img
                      src={`/site/logos/toolchain/${logo.slug}.svg`}
