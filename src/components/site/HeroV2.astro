---
---

<section id="overview" class="pl-hero-v2">
  <h1 class="pl-hero-v2-title">
    Write the docs.<br />Skip the busywork.
  </h1>

  <p class="pl-hero-v2-subtitle">
    Promptless suggests doc updates when your product changes. You review, edit, ship.
  </p>

  <form
    id="book-a-demo"
    class="pl-hero-v2-form"
    action="https://submit-form.com/roBOd2Oxb"
    method="post"
    data-redirect="/demo#book"
  >
    <label class="sr-only" for="work-email">Work email</label>
    <input id="work-email" type="email" name="email" placeholder="Work email" required />
    <input type="hidden" name="_redirect" value="/demo#book" />
    <button type="submit" name="submit" data-track-action="book_demo" data-track-funnel="conversion" data-track-location="hero">Get a demo</button>
  </form>
</section>

<script>
  (() => {
    const form = document.getElementById('book-a-demo');
    if (!(form instanceof HTMLFormElement)) return;

    const submitButton = form.querySelector('button[type="submit"]');
    const redirectInput = form.querySelector('input[name="_redirect"]');

    if (redirectInput instanceof HTMLInputElement) {
      redirectInput.value = `${window.location.origin}/demo#book`;
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const gtag = (window as any).gtag;
      if (typeof gtag === 'function') {
        gtag('event', 'cta_click', {
          funnel_stage: 'conversion',
          action: 'book_demo',
          location: 'hero',
          campaign: '',
          link_url: form.action,
        });
      }

      const email = (form.querySelector('input[name="email"]') as HTMLInputElement)?.value?.trim();
      if (email) {
        try { sessionStorage.setItem('pl_demo_email', email); } catch {}
      }
      (window as any).posthog?.capture('email_captured', {
        intent: 'demo',
        location: 'hero',
        campaign: '',
        ...(email ? { $set: { email } } : {}),
      });

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = 'Submitting...';
      }

      try {
        const formData = new FormData(form);
        const payload = new URLSearchParams();
        for (const [key, value] of formData.entries()) {
          if (typeof value === 'string') payload.append(key, value);
        }

        const response = await fetch(form.action, {
          method: 'POST',
          body: payload.toString(),
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            Accept: 'application/json',
          },
        });

        if (!response.ok) {
          throw new Error(`Formspark submission failed with status ${response.status}`);
        }

        const redirectTo = form.dataset.redirect || '/demo';
        window.location.assign(redirectTo);
      } catch (_error) {
        HTMLFormElement.prototype.submit.call(form);
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
          submitButton.textContent = 'Get a demo';
        }
      }
    });
  })();
</script>

<style>
  .pl-hero-v2 {
    padding: 3rem 0 2rem;
  }

  .pl-hero-v2-title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0;
    color: #111827;
  }

  .pl-hero-v2-subtitle {
    margin: 1.25rem 0 0;
    font-size: 1.1rem;
    line-height: 1.55;
    color: #4b5563;
    max-width: 28rem;
  }

  .pl-hero-v2-form {
    margin-top: 2rem;
    display: flex;
    gap: 0.75rem;
  }

  .pl-hero-v2-form input[type='email'] {
    flex: 1;
    min-width: 0;
    padding: 0.75rem 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    font-size: 1rem;
    outline: none;
  }

  .pl-hero-v2-form input[type='email']:focus {
    border-color: #506aea;
    box-shadow: 0 0 0 2px color-mix(in srgb, #506aea 30%, transparent);
  }

  .pl-hero-v2-form button {
    padding: 0.75rem 1.5rem;
    background: #0f172a;
    color: #fff;
    border: none;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
  }

  .pl-hero-v2-form button:hover {
    background: #506aea;
  }

  @media (max-width: 768px) {
    .pl-hero-v2 {
      padding: 2rem 0 1rem;
    }
  }
</style>
