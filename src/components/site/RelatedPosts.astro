---
import type { CollectionEntry } from 'astro:content';

interface Props {
  current: CollectionEntry<'blog'>;
  all: CollectionEntry<'blog'>[];
}

const { current, all } = Astro.props;

const others = all.filter((p) => p.id !== current.id);

// Prefer same tag, fill with recent
const sameTag = others.filter((p) => p.data.tag === current.data.tag);
const different = others.filter((p) => p.data.tag !== current.data.tag);

const sorted = [
  ...sameTag.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
  ...different.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
].slice(0, 3);
---

{sorted.length > 0 && (
  <div class="pl-related-posts">
    <h2>More from the blog</h2>
    <ul class="pl-related-posts-list">
      {sorted.map((post) => (
        <li>
          <a href={`/blog/${post.id}`}>{post.data.title}</a>
          {post.data.tag && <span class="pl-related-tag">{post.data.tag}</span>}
        </li>
      ))}
    </ul>
  </div>
)}
