---
import LiteYouTube from './LiteYouTube.astro';
import promptlessDemoPoster from '../../assets/site/promptless-demo-poster.png';

interface Props {
  id?: string;
  title?: string;
  src?: string;
}

const {
  id = 'video',
  title = 'Introducing Promptless 1.0',
  src = 'https://www.tella.tv/video/vid_cmkc3e0h900h804ii26qp01mo/embed?feature=oembed',
} = Astro.props;

const ytMatch = src.match(
  /(?:youtube\.com\/embed\/|youtu\.be\/|youtube\.com\/watch\?v=|youtube-nocookie\.com\/embed\/)([\w-]{6,})/
);
const ytId = ytMatch?.[1];
const localPoster = ytId === 'AONpRsZJkTY' ? promptlessDemoPoster : undefined;
---

<section id={id} data-section-tracked={id}>
  <div class="pl-site-video-embed">
    {ytId ? (
      <LiteYouTube id={ytId} title={title} poster={localPoster} />
    ) : (
      <iframe
        src={src}
        title={title}
        allowfullscreen
        allow="accelerometer *; encrypted-media *; gyroscope *; picture-in-picture *; fullscreen *"
      />
    )}
  </div>
</section>
