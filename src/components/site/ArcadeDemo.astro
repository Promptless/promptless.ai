---
import { Image } from 'astro:assets';
import poster from '../../assets/arcade-demo-header.png';
---

<div class="arcade-demo" style="position: relative; padding-bottom: calc(49.2797% + 41px); height: 0px; width: 100%;">
  <button class="arcade-demo-poster" aria-label="Play demo">
    <Image src={poster} alt="Promptless demo preview" width={1200} loading="lazy" />
  </button>
</div>

<style>
  .arcade-demo-poster {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
  }

  .arcade-demo-poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
  }

</style>

<script>
  document.querySelectorAll('.arcade-demo').forEach((container) => {
    const btn = container.querySelector('.arcade-demo-poster');
    if (!btn) return;

    btn.addEventListener('click', () => {
      const iframe = document.createElement('iframe');
      iframe.src =
        'https://demo.arcade.software/zk7LvTw9AQJSdiwabvyS?embed&embed_mobile=inline&embed_desktop=inline&squared=true&show_copy_link=true';
      iframe.title = 'Submit a Documentation Translation Task';
      iframe.frameBorder = '0';
      iframe.loading = 'lazy';
      iframe.allow = 'clipboard-write';
      iframe.allowFullscreen = true;
      iframe.style.cssText =
        'position: absolute; top: 0; left: 0; width: 100%; height: 100%; color-scheme: light;';

      btn.remove();
      container.appendChild(iframe);
    });
  });
</script>
