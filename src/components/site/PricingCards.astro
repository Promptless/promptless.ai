---
import GrowthBundleSelector from './pricing/GrowthBundleSelector.astro';
import PricingCard from './pricing/PricingCard.astro';
import {
  AGENT_ENTERPRISE_FEATURES,
  AGENT_ENTERPRISE_PLAN,
  AGENT_ENTERPRISE_USAGE,
  AGENT_GROWTH_FEATURES,
  AGENT_GROWTH_PLAN,
  AGENT_GROWTH_USAGE,
  AGENT_INSTRUCTIONS_FOOTNOTE,
  AGENT_STARTUP_FEATURES,
  AGENT_STARTUP_PLAN,
  AGENT_STARTUP_USAGE,
  ENTERPRISE_FEATURES,
  ENTERPRISE_PLAN,
  GROWTH_BUNDLE_OPTIONS,
  GROWTH_FEATURES,
  GROWTH_PLAN,
  STARTUP_DOC_UNITS,
  STARTUP_FEATURES,
  STARTUP_MONTHLY_USD,
  STARTUP_PLAN,
  formatPages,
  formatMonthlyUsd,
} from './pricing/pricing.config';

const defaultGrowthBundle = GROWTH_BUNDLE_OPTIONS[0];
---

<section class="pl-site-pricing" id="plans">
  <div class="pl-pricing-switcher not-content">
    <div class="pl-pricing-switcher-tablist" role="tablist" aria-label="Choose your Promptless pricing">
      <button
        id="pl-pricing-tab-agents"
        class="pl-pricing-switcher-pill is-active"
        role="tab"
        type="button"
        aria-selected="true"
        aria-controls="pl-pricing-panel-agents"
        tabindex="0"
      >
        <svg
          class="pl-pricing-switcher-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M12 8V4H8" />
          <rect width="16" height="12" x="4" y="8" rx="2" />
          <path d="M2 14h2" />
          <path d="M20 14h2" />
          <path d="M15 13v2" />
          <path d="M9 13v2" />
        </svg>
        <span class="pl-pricing-switcher-label">for agent instructions</span>
      </button>
      <button
        id="pl-pricing-tab-docs"
        class="pl-pricing-switcher-pill"
        role="tab"
        type="button"
        aria-selected="false"
        aria-controls="pl-pricing-panel-docs"
        tabindex="-1"
      >
        <svg
          class="pl-pricing-switcher-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M12 7v14" />
          <path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z" />
        </svg>
        <span class="pl-pricing-switcher-label">for customer-facing docs</span>
      </button>
    </div>
  </div>

  <div
    id="pl-pricing-panel-agents"
    class="pl-pricing-panel"
    role="tabpanel"
    aria-labelledby="pl-pricing-tab-agents"
  >
    <p class="pl-site-pricing-intro">Pricing scales with the number of agent instructions you govern.</p>

    <div class="pl-site-pricing-grid">
      <PricingCard
        planId={AGENT_STARTUP_PLAN.id}
        title={AGENT_STARTUP_PLAN.title}
        summary={AGENT_STARTUP_PLAN.summary}
        priceLabel="Contact us"
        usageLabel={AGENT_STARTUP_USAGE}
        features={AGENT_STARTUP_FEATURES}
        ctaLabel={AGENT_STARTUP_PLAN.ctaLabel}
        ctaHref={AGENT_STARTUP_PLAN.ctaHref}
        ctaAction={AGENT_STARTUP_PLAN.ctaAction}
      />

      <PricingCard
        planId={AGENT_GROWTH_PLAN.id}
        title={AGENT_GROWTH_PLAN.title}
        summary={AGENT_GROWTH_PLAN.summary}
        priceLabel="Contact us"
        usageLabel={AGENT_GROWTH_USAGE}
        leadIn="Everything in Startup, plus"
        features={AGENT_GROWTH_FEATURES}
        ctaLabel={AGENT_GROWTH_PLAN.ctaLabel}
        ctaHref={AGENT_GROWTH_PLAN.ctaHref}
        ctaAction={AGENT_GROWTH_PLAN.ctaAction}
      />

      <PricingCard
        planId={AGENT_ENTERPRISE_PLAN.id}
        title={AGENT_ENTERPRISE_PLAN.title}
        summary={AGENT_ENTERPRISE_PLAN.summary}
        priceLabel="Contact us"
        usageLabel={AGENT_ENTERPRISE_USAGE}
        leadIn="Everything in Growth, plus"
        features={AGENT_ENTERPRISE_FEATURES}
        ctaLabel={AGENT_ENTERPRISE_PLAN.ctaLabel}
        ctaHref={AGENT_ENTERPRISE_PLAN.ctaHref}
        ctaAction={AGENT_ENTERPRISE_PLAN.ctaAction}
      />
    </div>

    <p class="pl-site-pricing-footnote">{AGENT_INSTRUCTIONS_FOOTNOTE}</p>
  </div>

  <div
    id="pl-pricing-panel-docs"
    class="pl-pricing-panel"
    role="tabpanel"
    aria-labelledby="pl-pricing-tab-docs"
    hidden
  >
    <p class="pl-site-pricing-trial-badge">All plans include a 14-day free trial.</p>
    <p class="pl-site-pricing-intro">Pricing scales with the size and complexity of your docs site.</p>
    <p class="pl-site-pricing-oss-line">
      Open-source, non-commercial project? <a href="https://promptless.ai/docs/start-here/open-source-quickstart">Learn about our OSS program</a>.
    </p>

    <div class="pl-site-pricing-grid">
      <PricingCard
        planId={STARTUP_PLAN.id}
        title={STARTUP_PLAN.title}
        summary={STARTUP_PLAN.summary}
        priceLabel={`${formatMonthlyUsd(STARTUP_MONTHLY_USD)}/mo`}
        usageLabel={`Up to ${formatPages(STARTUP_DOC_UNITS)}`}
        features={STARTUP_FEATURES}
        ctaLabel={STARTUP_PLAN.ctaLabel}
        ctaHref={STARTUP_PLAN.ctaHref}
        ctaAction={STARTUP_PLAN.ctaAction}
      />

      <PricingCard
        planId={GROWTH_PLAN.id}
        title={GROWTH_PLAN.title}
        summary={GROWTH_PLAN.summary}
        priceLabel={defaultGrowthBundle.priceLabel}
        leadIn="Everything in Startup, plus"
        features={GROWTH_FEATURES}
        ctaLabel={GROWTH_PLAN.ctaLabel}
        ctaHref={GROWTH_PLAN.ctaHref}
        ctaAction={GROWTH_PLAN.ctaAction}
        priceDataAttr="data-growth-price"
      >
        <GrowthBundleSelector slot="selector" bundles={GROWTH_BUNDLE_OPTIONS} selectedBundleId={defaultGrowthBundle.id} />
      </PricingCard>

      <PricingCard
        planId={ENTERPRISE_PLAN.id}
        title={ENTERPRISE_PLAN.title}
        summary={ENTERPRISE_PLAN.summary}
        priceLabel="Custom"
        usageLabel="Unlimited Pages"
        leadIn="Everything in Growth, plus"
        features={ENTERPRISE_FEATURES}
        ctaLabel={ENTERPRISE_PLAN.ctaLabel}
        ctaHref={ENTERPRISE_PLAN.ctaHref}
        ctaAction={ENTERPRISE_PLAN.ctaAction}
      />
    </div>

    <p class="pl-site-pricing-footnote">
      * Pages are normalized—a long API reference counts as multiple pages, while short changelog entries may share one.
    </p>
  </div>
</section>

<script>
  (() => {
    const root = document.querySelector('.pl-pricing-switcher');
    if (!(root instanceof HTMLElement)) return;

    const pills = Array.from(root.querySelectorAll<HTMLButtonElement>('.pl-pricing-switcher-pill'));
    if (pills.length === 0) return;

    const panelFor = (pill: HTMLButtonElement) => {
      const id = pill.getAttribute('aria-controls');
      return id ? document.getElementById(id) : null;
    };

    // Plain click-to-switch (no auto-rotate on pricing). Manual activation:
    // arrow keys move focus with a roving tabindex; Enter/Space or click select.
    const activate = (index: number, { focus = false } = {}) => {
      pills.forEach((pill, i) => {
        const isActive = i === index;
        pill.classList.toggle('is-active', isActive);
        pill.setAttribute('aria-selected', String(isActive));
        pill.tabIndex = isActive ? 0 : -1;
        const panel = panelFor(pill);
        if (panel) {
          if (isActive) {
            panel.removeAttribute('hidden');
          } else {
            panel.setAttribute('hidden', '');
          }
        }
      });
      if (focus) pills[index].focus();
    };

    const moveFocus = (toIndex: number) => {
      pills.forEach((pill, i) => {
        pill.tabIndex = i === toIndex ? 0 : -1;
      });
      pills[toIndex].focus();
    };

    pills.forEach((pill, index) => {
      pill.addEventListener('click', () => activate(index, { focus: true }));

      pill.addEventListener('keydown', (event) => {
        switch (event.key) {
          case 'ArrowRight':
          case 'ArrowDown': {
            event.preventDefault();
            moveFocus((index + 1) % pills.length);
            break;
          }
          case 'ArrowLeft':
          case 'ArrowUp': {
            event.preventDefault();
            moveFocus((index - 1 + pills.length) % pills.length);
            break;
          }
          case 'Home': {
            event.preventDefault();
            moveFocus(0);
            break;
          }
          case 'End': {
            event.preventDefault();
            moveFocus(pills.length - 1);
            break;
          }
          case 'Enter':
          case ' ':
          case 'Spacebar': {
            event.preventDefault();
            activate(index, { focus: true });
            break;
          }
          default:
            break;
        }
      });
    });
  })();
</script>

<style>
  .pl-pricing-switcher {
    display: flex;
    justify-content: center;
    width: 100%;
    margin: 0 0 2rem;
  }

  .pl-pricing-switcher-tablist {
    display: inline-flex;
    align-items: stretch;
    gap: 0.5rem;
    background: #f3f4f6;
    border-radius: 999px;
    padding: 0.35rem;
  }

  .pl-pricing-switcher-pill {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    padding: 0.55rem 1.15rem;
    border: none;
    border-radius: 999px;
    background: transparent;
    color: #6b7280;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
    cursor: pointer;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .pl-pricing-switcher-pill:hover {
    color: #111827;
  }

  .pl-pricing-switcher-pill.is-active {
    background: #fff;
    color: #111827;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
  }

  .pl-pricing-switcher-pill:focus-visible {
    outline: 2px solid #506aea;
    outline-offset: 2px;
  }

  .pl-pricing-switcher-icon {
    flex-shrink: 0;
  }

  .pl-pricing-switcher-label {
    display: inline-block;
  }

  @media (max-width: 768px) {
    .pl-pricing-switcher-tablist {
      width: 100%;
      flex-direction: column;
      border-radius: 1rem;
      gap: 0.35rem;
    }

    .pl-pricing-switcher-pill {
      justify-content: center;
      border-radius: 0.75rem;
    }
  }
</style>
