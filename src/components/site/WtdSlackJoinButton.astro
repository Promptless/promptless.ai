---
/**
 * Branded "Join the Writing Day Slack" CTA button used on the
 * Write the Docs Portland 2026 — Writing Day blog post.
 *
 * Reuses the existing Slack logo at `public/assets/slack-logo.svg`
 * and is styled in Slack's aubergine to feel branded and inviting.
 */

interface Props {
  label?: string;
  href?: string;
}

const {
  label = 'Join the Writing Day Slack',
  href = 'https://join.slack.com/t/writingday2026/shared_invite/zt-3wuwhf7lt-DbAN_KqGhwUxQn1FXcTHlQ',
} = Astro.props as Props;
---

<a
  class="wtd-slack-btn"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  data-track-action="wtd_join_slack"
  data-track-funnel="engagement"
  data-track-location="wtd_writing_day_blog"
>
  <img
    class="wtd-slack-btn-logo"
    src="/assets/slack-logo.svg"
    alt=""
    aria-hidden="true"
    width="20"
    height="20"
  />
  <span class="wtd-slack-btn-text">{label}</span>
</a>

<style>
  .wtd-slack-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin: 1.25rem 0;
    padding: 0.7rem 1.1rem;
    background: #4A154B;
    color: #fff !important;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    border-radius: 0.5rem;
    text-decoration: none;
    box-shadow: 0 1px 2px rgba(74, 21, 75, 0.18);
    transition: background 140ms ease, transform 140ms ease, box-shadow 140ms ease;
  }

  .wtd-slack-btn:visited,
  .wtd-slack-btn:hover,
  .wtd-slack-btn:active {
    color: #fff !important;
  }

  .wtd-slack-btn:hover {
    background: #611f64;
    box-shadow: 0 4px 12px rgba(74, 21, 75, 0.25);
    transform: translateY(-1px);
  }

  .wtd-slack-btn:focus-visible {
    outline: 2px solid #4A154B;
    outline-offset: 2px;
  }

  .wtd-slack-btn-logo {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    background: #fff;
    border-radius: 4px;
    padding: 2px;
  }

  .wtd-slack-btn-text {
    line-height: 1;
  }
</style>
