---
import { Image } from 'astro:assets';
import mannyImg from '../../assets/site/manny.jpeg';
import alanImg from '../../assets/site/alan.jpeg';
import moImg from '../../assets/site/mo.jpeg';
import aaronImg from '../../assets/site/aaron.jpeg';
import eduardoImg from '../../assets/site/eduardo.jpeg';
import nicholasImg from '../../assets/site/nicholas.jpeg';
import docDetectiveLogo from '../../assets/site/logos/doc-detective.png';
import type { ImageMetadata } from 'astro';

interface Testimonial {
  quote: string;
  author: string;
  title: string;
  company: string;
  companyLogo: ImageMetadata | string;
  image: ImageMetadata;
}

const testimonials: Testimonial[] = [
  {
    quote:
      'Promptless dramatically speeds up my time-to-first-draft. My team literally calls me a 10x tech writer.',
    author: 'Mo King',
    title: 'Senior Technical Writer',
    company: 'Runpod',
    companyLogo: '/site/logos/runpod.png',
    image: moImg,
  },
  {
    quote:
      'Promptless is a core part of my self-healing docs toolchain, proactively fixing problems before I knew I had them.',
    author: 'Manny Silva',
    title: 'Creator',
    company: 'Doc Detective',
    companyLogo: docDetectiveLogo,
    image: mannyImg,
  },
  {
    quote:
      'This is the most "make something people want" feature I have ever seen. It solves my problem in a better way than I thought would be possible.',
    author: 'Alan Mond',
    title: 'Docs Maintainer',
    company: 'Bazel',
    companyLogo: '/site/logos/bazel-icon.png',
    image: alanImg,
  },
  {
    quote:
      "Promptless updates every relevant section of our docs, catching both the latest changes and old spots we'd missed. It feels like magic.",
    author: 'Aaron Levin',
    title: 'Founding Solutions Engineer',
    company: 'Vellum',
    companyLogo: '/site/logos/vellum-icon.svg',
    image: aaronImg,
  },
  {
    quote: 'I love your product. It works incredibly well and basically pays for itself right away.',
    author: 'Eduardo Soubihe',
    title: 'CTO',
    company: 'Latitude.sh',
    companyLogo: '/site/logos/latitude.svg',
    image: eduardoImg,
  },
  {
    quote: "Promptless is a solo tech writer's godsend.",
    author: 'Nicholas DeWald',
    title: 'Head of Developer Docs',
    company: 'Prove',
    companyLogo: '/site/logos/prove-icon.svg',
    image: nicholasImg,
  },
];
---

<div class="pl-testimonials-vertical">
  <div class="pl-testimonials-vertical-track">
    {
      [...testimonials, ...testimonials].map((item) => (
        <blockquote class="pl-testimonials-vertical-card">
          <p class="pl-testimonials-vertical-quote">{item.quote}</p>
          <div class="pl-testimonials-vertical-footer">
            <div class="pl-testimonials-vertical-person">
              <Image src={item.image} alt={item.author} loading="lazy" width={80} height={80} />
              <div class="pl-testimonials-vertical-meta">
                <p class="pl-testimonials-vertical-author">{item.author}</p>
                <p class="pl-testimonials-vertical-title">{item.title}</p>
                <p class="pl-testimonials-vertical-company">{item.company}</p>
              </div>
            </div>
            <div class="pl-testimonials-vertical-logo">
              {typeof item.companyLogo === 'string' ? (
                <img src={item.companyLogo} alt={`${item.company} logo`} loading="lazy" />
              ) : (
                <Image src={item.companyLogo} alt={`${item.company} logo`} loading="lazy" width={40} height={40} />
              )}
            </div>
          </div>
        </blockquote>
      ))
    }
  </div>
</div>

<style>
  .pl-testimonials-vertical {
    height: 24rem;
    overflow: hidden;
    position: relative;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
  }

  .pl-testimonials-vertical-track {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    animation: testimonials-scroll-up 21s ease-in-out infinite;
    margin-top: -100px;
  }

  /* 6 cards, each dwells ~3s then scrolls ~0.5s. Total 21s. */
  @keyframes testimonials-scroll-up {
    0%      { transform: translateY(0); }
    14.28%  { transform: translateY(0); }
    16.66%  { transform: translateY(-8.333%); }

    16.67%  { transform: translateY(-8.333%); }
    30.95%  { transform: translateY(-8.333%); }
    33.33%  { transform: translateY(-16.666%); }

    33.34%  { transform: translateY(-16.666%); }
    47.62%  { transform: translateY(-16.666%); }
    50.00%  { transform: translateY(-25%); }

    50.01%  { transform: translateY(-25%); }
    64.28%  { transform: translateY(-25%); }
    66.66%  { transform: translateY(-33.333%); }

    66.67%  { transform: translateY(-33.333%); }
    80.95%  { transform: translateY(-33.333%); }
    83.33%  { transform: translateY(-41.666%); }

    83.34%  { transform: translateY(-41.666%); }
    97.62%  { transform: translateY(-41.666%); }
    100%    { transform: translateY(-50%); }
  }

  .pl-testimonials-vertical-track:hover {
    animation-play-state: paused;
  }

  .pl-testimonials-vertical-card {
    margin: 0;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    background: #ffffff;
    padding: 1.05rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    flex-shrink: 0;
  }

  .pl-testimonials-vertical-quote {
    margin: 0;
    color: #374151;
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .pl-testimonials-vertical-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
  }

  .pl-testimonials-vertical-person {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
  }

  .pl-testimonials-vertical-person img {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .pl-testimonials-vertical-author {
    margin: 0;
    color: #111827;
    font-weight: 600;
    font-size: 0.875rem;
    line-height: 1.3;
  }

  .pl-testimonials-vertical-title,
  .pl-testimonials-vertical-company {
    margin: 0;
    color: #6b7280;
    font-size: 0.8rem;
    line-height: 1.3;
  }

  .pl-testimonials-vertical-logo {
    border: 1px solid #e5e7eb;
    border-radius: 0.45rem;
    padding: 0.35rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pl-testimonials-vertical-logo img {
    height: 1.25rem;
    max-height: 1.25rem;
    max-width: 6rem;
    width: auto;
    display: block;
    object-fit: contain;
  }
</style>
