---
import PrimaryTabs from './PrimaryTabs.astro';
import { getActiveSection, type SiteSection } from '@lib/site-navigation';

interface Props {
  activeSection?: SiteSection;
  showNavTools?: boolean;
}

const { activeSection = getActiveSection(Astro.url.pathname), showNavTools = false } = Astro.props;
---

<div class="pl-site-header">
  <div class:list={['pl-site-header-row', { 'has-tools': showNavTools }]}>
    <slot name="brand">
      <a class="pl-site-logo-link" href="/">
        <img src="/site/logo_light.svg" alt="Promptless" width="174" height="50" loading="eager" />
      </a>
    </slot>
    {showNavTools ? <div class="pl-site-search sl-flex print:hidden"><slot name="nav-tools" /></div> : null}
    <div class="pl-site-cta-row">
      <a class="pl-site-cta pl-site-cta-login" href="https://app.gopromptless.ai" data-track-action="login" data-track-location="nav">Login</a>
      <a class="pl-site-cta pl-site-cta-secondary" href="/demo" data-track-action="book_demo" data-track-funnel="conversion" data-track-location="nav">Get a demo</a>
      <a class="pl-site-cta" href="https://accounts.gopromptless.ai/sign-up" data-track-action="sign_up" data-track-funnel="conversion" data-track-location="nav">Start for free</a>
    </div>
  </div>

  <div class="pl-site-nav-row">
    <PrimaryTabs activeSection={activeSection} />
  </div>
</div>
