{
  "tests": [
    {
      "testId": "notion-integration-setup",
      "description": "Verify Notion integration setup flow from integrations page",
      "steps": [
        {
          "description": "Start recording the Notion integration setup flow",
          "record": ".doc-detective/results/notion-integration-setup.mp4"
        },
        {
          "description": "Navigate to the Integrations page",
          "goTo": "https://app.gopromptless.ai/integrations"
        },
        {
          "description": "Wait for page load and authentication redirect",
          "wait": 3000
        },
        {
          "description": "Verify the Notion integration card is visible",
          "find": {
            "selector": "[data-testid='notion-integration-card'], [data-integration='notion'], .integration-card:has-text('Notion')",
            "timeout": 10000
          }
        },
        {
          "description": "Find and click the Connect button on the Notion card",
          "find": {
            "selector": "[data-testid='notion-connect-button'], [data-integration='notion'] button:has-text('Connect'), .integration-card:has-text('Notion') button",
            "click": true,
            "timeout": 5000
          }
        },
        {
          "description": "Wait for Notion OAuth flow to initiate",
          "wait": 2000
        },
        {
          "description": "Stop recording",
          "stopRecord": true
        }
      ]
    }
  ]
}
