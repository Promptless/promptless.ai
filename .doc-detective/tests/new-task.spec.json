{
  "tests": [
    {
      "testId": "new-task-form",
      "description": "Log in and fill out the New Task form for screenshot",
      "steps": [
        {
          "description": "Navigate to the sign-in page",
          "goTo": "https://accounts.gopromptless.ai/sign-in"
        },
        {
          "description": "Click the email input",
          "find": {
            "selector": "#identifier-field",
            "click": true
          }
        },
        {
          "description": "Type the test email",
          "type": "$PROMPTLESS_TEST_EMAIL"
        },
        {
          "description": "Click Continue after email",
          "find": {
            "selector": "button.cl-formButtonPrimary",
            "click": true,
            "timeout": 5000
          }
        },
        {
          "description": "Wait for password page to load",
          "wait": 3000
        },
        {
          "description": "Click the password input",
          "find": {
            "selector": "#password-field",
            "click": true,
            "timeout": 10000
          }
        },
        {
          "description": "Type the test password",
          "type": "$PROMPTLESS_TEST_PASSWORD"
        },
        {
          "description": "Click Continue to sign in",
          "find": {
            "selector": "button.cl-formButtonPrimary",
            "click": true,
            "timeout": 5000
          }
        },
        {
          "description": "Wait for sign-in to complete",
          "wait": 5000
        },
        {
          "description": "Navigate to the New Task page",
          "goTo": "https://app.gopromptless.ai/new-task"
        },
        {
          "description": "Wait for the page to load",
          "wait": 3000
        },
        {
          "description": "Verify the task description field exists",
          "find": {
            "selector": "textarea",
            "timeout": 10000
          }
        },
        {
          "description": "Click the task description field",
          "find": {
            "selector": "textarea",
            "click": true
          }
        },
        {
          "description": "Type an example task description",
          "type": "Document how to configure webhooks for external integrations. Include setup steps and example payloads."
        },
        {
          "description": "Wait for input to register",
          "wait": 1000
        },
        {
          "description": "Screenshot the filled New Task form",
          "screenshot": ".doc-detective/results/new-task-form-filled.png"
        }
      ]
    }
  ]
}
