{
  "input": "src/content/docs",
  "fileTypes": [
    {
      "extends": "markdown",
      "extensions": ["mdx"]
    }
  ],
  "output": ".doc-detective/results",
  "recursive": true,
  "origin": "https://promptless.ai",
  "detectSteps": false,
  "loadVariables": ".doc-detective/.env",
  "runOn": [
    {
      "platforms": ["mac"],
      "browsers": [
        {
          "name": "chrome",
          "headless": false
        }
      ]
    }
  ]
}
